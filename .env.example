# Etsy IP Defense Kit — Environment Variables
# Copy this file to .env.local for local development
# In production, set these in Vercel Dashboard → Project → Settings → Environment Variables

# ── STRIPE (set after approval gate is confirmed) ──────────────────────────────
STRIPE_SECRET_KEY=sk_live_...          # From Stripe Dashboard → API Keys
STRIPE_WEBHOOK_SECRET=whsec_...        # From Stripe Dashboard → Webhooks (after creating webhook)
NEXT_PUBLIC_STRIPE_PAYMENT_LINK=https://buy.stripe.com/... # Created after approval

# ── RESEND (request RESEND_API_KEY from Orchestrator) ──────────────────────────
RESEND_API_KEY=re_...                  # From resend.com → API Keys

# ── DELIVERY ──────────────────────────────────────────────────────────────────
# Generate a long random string (e.g.: openssl rand -hex 32)
# This is the private path to the download file
DOWNLOAD_SECRET_PATH=your-very-long-random-string-here-replace-this

# ── SITE ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://sellerdefensekit.com   # Update after Vercel deployment
FROM_EMAIL=noreply@sellerdefensekit.com             # Must be a verified Resend domain
